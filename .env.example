# ─── AWS Configuration ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# ─── ECR Repositories ────────────────────────────────────────
ECR_REPOSITORY_FRONTEND=ecommerce-frontend
ECR_REPOSITORY_BACKEND=ecommerce-backend

# ─── ECS Configuration ───────────────────────────────────────
ECS_CLUSTER_NAME=ecommerce-cluster
ECS_SERVICE_FRONTEND=ecommerce-frontend-service
ECS_SERVICE_BACKEND=ecommerce-backend-service

# ─── Database ────────────────────────────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=your_secure_password_here

# ─── App Config ──────────────────────────────────────────────
NODE_ENV=production
JWT_SECRET=your_jwt_secret_here
FRONTEND_URL=https://yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# ─── Stripe (Payments) ───────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx

# ─── Local Dev Only ──────────────────────────────────────────
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
